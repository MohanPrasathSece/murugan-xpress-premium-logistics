# ── SMTP Configuration ──────────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password   (use an App Password, not your login password)
#
# Other providers (Outlook, Zoho, custom):
#   SMTP_HOST=smtp.office365.com  (Outlook)
#   SMTP_HOST=smtp.zoho.com       (Zoho)
#   SMTP_PORT=587
#   SMTP_SECURE=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Email address that receives all booking notifications
BOOKING_EMAIL=muruganxpress6@gmail.com

# API server port (default 3001)
PORT=3001
